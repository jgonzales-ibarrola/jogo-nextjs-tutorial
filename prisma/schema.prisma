generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Hello {
  id String @id @default(cuid())
  content String
  age Int
  price Decimal
  visitDate DateTime
  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([content])
}